        { "type": "typed_word", "settings": { "word": "a Slump" } },
        { "type": "typed_word", "settings": { "word": "Fatigue" } },
        { "type": "typed_word", "settings": { "word": "Brain Fog" } }
      ]
    }
  ]
}
{% endschema %}
