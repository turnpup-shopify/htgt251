{%- liquid
  assign d_top = section.settings.padding_top_desktop
  assign d_right = section.settings.padding_right_desktop
  assign d_bottom = section.settings.padding_bottom_desktop
  assign d_left = section.settings.padding_left_desktop
  assign m_top = section.settings.padding_top_mobile
  assign m_right = section.settings.padding_right_mobile
  assign m_bottom = section.settings.padding_bottom_mobile
  assign m_left = section.settings.padding_left_mobile
-%}

<size-calculator
  class="size-calculator"
  id="SizeCalculator-{{ section.id }}"
  data-mode="{{ section.settings.calc_mode }}"
  data-multiplier="{{ section.settings.multiplier }}"
  data-offset-min="{{ section.settings.offset_min }}"
  data-offset-max="{{ section.settings.offset_max }}"
  data-round-to="{{ section.settings.round_to }}"
  data-input-min="{{ section.settings.input_min }}"
  data-input-max="{{ section.settings.input_max }}"
  data-unit="{{ section.settings.unit_label | escape }}"
  data-result-prefix="{{ section.settings.result_prefix | escape }}"
  data-result-suffix="{{ section.settings.result_suffix | escape }}"
  data-error-range="{{ section.settings.error_range | escape }}"
  data-error-empty="{{ section.settings.error_empty | escape }}"
  style="
    --sc-max-width: {{ section.settings.max_width }}px;
    --sc-accent: {{ section.settings.accent_color }};
    --sc-surface: {{ section.settings.surface_color }};
    --sc-border: {{ section.settings.border_color }};
    --sc-radius: {{ section.settings.corner_radius }}px;
    --sc-heading-font-family: {{ section.settings.heading_font_family | default: 'inherit' }};
    --sc-heading-font-size: {{ section.settings.heading_font_size }}px;
    --sc-heading-font-weight: {{ section.settings.heading_font_weight }};
    --sc-heading-color: {{ section.settings.heading_font_color }};
    --sc-body-font-family: {{ section.settings.body_font_family | default: 'inherit' }};
    --sc-body-font-size: {{ section.settings.body_font_size }}px;
    --sc-body-font-weight: {{ section.settings.body_font_weight }};
    --sc-body-color: {{ section.settings.body_font_color }};
    --sc-result-font-family: {{ section.settings.result_font_family | default: 'inherit' }};
    --sc-result-font-size: {{ section.settings.result_font_size }}px;
    --sc-result-font-weight: {{ section.settings.result_font_weight }};
    --sc-result-color: {{ section.settings.result_font_color }};
    --sc-padding-block-start: {{ m_top }}px;
    --sc-padding-inline-end: {{ m_right }}px;
    --sc-padding-block-end: {{ m_bottom }}px;
    --sc-padding-inline-start: {{ m_left }}px;
    --sc-padding-block-start-lg: {{ d_top }}px;
    --sc-padding-inline-end-lg: {{ d_right }}px;
    --sc-padding-block-end-lg: {{ d_bottom }}px;
    --sc-padding-inline-start-lg: {{ d_left }}px;
  "
>
  {%- if section.settings.calc_mode == 'ranges' -%}
    {%- capture ranges_json -%}
      [
      {%- for block in section.blocks -%}
        {%- if block.type == 'range' -%}
          {
            "min": {{ block.settings.min_value | default: 0 }},
            "max": {{ block.settings.max_value | default: 0 }},
            "result": {{ block.settings.result_label | default: '' | json }},
            "note": {{ block.settings.result_note | default: '' | json }},
            "link": {{ block.settings.link_url | default: '' | json }},
            "linkLabel": {{ block.settings.link_label | default: '' | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endif -%}
      {%- endfor -%}
      ]
    {%- endcapture -%}
    <script type="application/json" data-size-calculator-ranges>
      {{ ranges_json }}
    </script>
  {%- endif -%}

  <div class="size-calculator__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="size-calculator__heading" id="SizeCalculatorHeading-{{ section.id }}">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    {%- if section.settings.intro != blank -%}
      <div class="size-calculator__intro">{{ section.settings.intro }}</div>
    {%- endif -%}

    <div class="size-calculator__field">
      <label class="size-calculator__label" for="SizeCalculatorInput-{{ section.id }}">
        {{ section.settings.input_label | escape }}
      </label>

      <div class="size-calculator__controls">
        <input
          class="size-calculator__input"
          type="number"
          inputmode="decimal"
          id="SizeCalculatorInput-{{ section.id }}"
          name="size_calculator_input"
          min="{{ section.settings.input_min }}"
          max="{{ section.settings.input_max }}"
          step="{{ section.settings.input_step }}"
          placeholder="{{ section.settings.input_placeholder | escape }}"
          aria-describedby="SizeCalculatorError-{{ section.id }}"
          data-size-calculator-input
        >
        <button
          class="size-calculator__button"
          type="button"
          data-size-calculator-submit
        >
          {{ section.settings.button_label | escape }}
        </button>
      </div>

      <p
        class="size-calculator__error"
        id="SizeCalculatorError-{{ section.id }}"
        role="alert"
        hidden
        data-size-calculator-error
      ></p>
    </div>

    <output
      class="size-calculator__result"
      for="SizeCalculatorInput-{{ section.id }}"
      aria-live="polite"
      hidden
      data-size-calculator-result
    ></output>

    {%- if section.settings.fallback_note != blank -%}
      <noscript>
        <p class="size-calculator__intro">{{ section.settings.fallback_note }}</p>
      </noscript>
    {%- endif -%}

    {%- content_for 'blocks' -%}
  </div>
</size-calculator>

{% stylesheet %}
  .size-calculator {
    display: block;
    box-sizing: border-box;
    max-width: 100%;
    padding-block-start: var(--sc-padding-block-start, 0);
    padding-block-end: var(--sc-padding-block-end, 0);
    padding-inline-start: var(--sc-padding-inline-start, 0);
    padding-inline-end: var(--sc-padding-inline-end, 0);
    overflow-wrap: break-word;

    @media screen and (min-width: 750px) {
      padding-block-start: var(--sc-padding-block-start-lg, 0);
      padding-block-end: var(--sc-padding-block-end-lg, 0);
      padding-inline-start: var(--sc-padding-inline-start-lg, 0);
      padding-inline-end: var(--sc-padding-inline-end-lg, 0);
    }
  }

  .size-calculator__inner {
    box-sizing: border-box;
    width: min(100%, var(--sc-max-width, 720px));
    margin-inline: auto;
    padding: 1.5rem;
    border: 1px solid var(--sc-border, #e5e5e5);
    border-radius: var(--sc-radius, 0);
    background: var(--sc-surface, transparent);
  }

  .size-calculator__heading {
    margin-block: 0 0.5rem;
    font-family: var(--sc-heading-font-family, inherit);
    font-size: var(--sc-heading-font-size, 24px);
    font-weight: var(--sc-heading-font-weight, 600);
    line-height: 1.2;
    color: var(--sc-heading-color, inherit);
  }

  .size-calculator__intro {
    margin-block: 0 1.25rem;
    font-family: var(--sc-body-font-family, inherit);
    font-size: var(--sc-body-font-size, 16px);
    font-weight: var(--sc-body-font-weight, 400);
    line-height: 1.5;
    color: var(--sc-body-color, inherit);

    & > :last-child {
      margin-block-end: 0;
    }
  }

  .size-calculator__label {
    display: block;
    margin-block-end: 0.5rem;
    font-family: var(--sc-body-font-family, inherit);
    font-size: var(--sc-body-font-size, 16px);
    font-weight: 600;
    color: var(--sc-body-color, inherit);
  }

  .size-calculator__controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .size-calculator__input {
    flex: 1 1 12rem;
    box-sizing: border-box;
    min-width: 0;
    min-height: 44px;
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--sc-border, #e5e5e5);
    border-radius: var(--sc-radius, 0);
    font-family: var(--sc-body-font-family, inherit);
    font-size: 16px;
    color: var(--sc-body-color, inherit);
    background: #fff;

    &[aria-invalid='true'] {
      border-color: #b3261e;
    }

    &:focus-visible {
      outline: 2px solid var(--sc-accent, #111);
      outline-offset: 2px;
    }
  }

  .size-calculator__button {
    flex: 0 0 auto;
    min-height: 44px;
    padding-inline: 1.5rem;
    border: 1px solid var(--sc-accent, #111);
    border-radius: var(--sc-radius, 0);
    font-family: var(--sc-body-font-family, inherit);
    font-size: var(--sc-body-font-size, 16px);
    font-weight: 600;
    color: #fff;
    background: var(--sc-accent, #111);
    cursor: pointer;
    transition: opacity 0.15s ease;

    &:hover {
      opacity: 0.85;
    }

    &:focus-visible {
      outline: 2px solid var(--sc-accent, #111);
      outline-offset: 2px;
    }
  }

  .size-calculator__error {
    margin-block: 0.625rem 0;
    font-family: var(--sc-body-font-family, inherit);
    font-size: 0.875rem;
    color: #b3261e;

    &[hidden] {
      display: none;
    }
  }

  .size-calculator__result {
    display: block;
    margin-block-start: 1.25rem;
    padding-block-start: 1.25rem;
    border-block-start: 1px solid var(--sc-border, #e5e5e5);

    &[hidden] {
      display: none;
    }
  }

  .size-calculator__result-value {
    display: block;
    font-family: var(--sc-result-font-family, inherit);
    font-size: var(--sc-result-font-size, 28px);
    font-weight: var(--sc-result-font-weight, 600);
    line-height: 1.2;
    color: var(--sc-result-color, inherit);
  }

  .size-calculator__result-note {
    display: block;
    margin-block-start: 0.5rem;
    font-family: var(--sc-body-font-family, inherit);
    font-size: var(--sc-body-font-size, 16px);
    line-height: 1.5;
    color: var(--sc-body-color, inherit);
  }

  .size-calculator__result-link {
    display: inline-block;
    margin-block-start: 0.75rem;
    font-family: var(--sc-body-font-family, inherit);
    font-size: var(--sc-body-font-size, 16px);
    font-weight: 600;
    color: var(--sc-accent, #111);

    &:focus-visible {
      outline: 2px solid var(--sc-accent, #111);
      outline-offset: 2px;
    }
  }

  @media (forced-colors: active) {
    .size-calculator__input:focus-visible,
    .size-calculator__button:focus-visible {
      outline: 3px solid LinkText;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .size-calculator__button {
      transition-duration: 0.01ms;
    }
  }
{% endstylesheet %}

{% javascript %}
  class SizeCalculator extends HTMLElement {
    #input = null;
    #button = null;
    #result = null;
    #error = null;
    #ranges = [];

    connectedCallback() {
      this.#input = this.querySelector('[data-size-calculator-input]');
      this.#button = this.querySelector('[data-size-calculator-submit]');
      this.#result = this.querySelector('[data-size-calculator-result]');
      this.#error = this.querySelector('[data-size-calculator-error]');
      this.#ranges = this.#readRanges();

      this.#button?.addEventListener('click', this.#handleSubmit);
      this.#input?.addEventListener('keydown', this.#handleKeydown);
    }

    disconnectedCallback() {
      this.#button?.removeEventListener('click', this.#handleSubmit);
      this.#input?.removeEventListener('keydown', this.#handleKeydown);
    }

    #readRanges() {
      const node = this.querySelector('[data-size-calculator-ranges]');
      if (!node) return [];

      try {
        const parsed = JSON.parse(node.textContent);
        return Array.isArray(parsed) ? parsed : [];
      } catch (error) {
        console.error('Size calculator: bad range data', error);
        return [];
      }
    }

    #handleKeydown = (event) => {
      if (event.key !== 'Enter') return;
      event.preventDefault();
      this.#calculate();
    };

    #handleSubmit = () => {
      this.#calculate();
    };

    #round(value) {
      const step = Number(this.dataset.roundTo) || 1;
      const rounded = Math.round(value / step) * step;
      return Number(rounded.toFixed(2));
    }

    #format(value) {
      const unit = this.dataset.unit || '';
      return unit ? `${value} ${unit}` : `${value}`;
    }

    #showError(message) {
      if (!this.#error) return;
      this.#error.textContent = message;
      this.#error.hidden = false;
      this.#input?.setAttribute('aria-invalid', 'true');
      if (this.#result) this.#result.hidden = true;
    }

    #clearError() {
      if (!this.#error) return;
      this.#error.hidden = true;
      this.#error.textContent = '';
      this.#input?.removeAttribute('aria-invalid');
    }

    #render(value, note, link, linkLabel) {
      if (!this.#result) return;

      const prefix = this.dataset.resultPrefix || '';
      const suffix = this.dataset.resultSuffix || '';
      const parts = [];

      parts.push(`<span class="size-calculator__result-value">${prefix} ${value} ${suffix}`.trim() + '</span>');

      if (note) {
        parts.push(`<span class="size-calculator__result-note">${note}</span>`);
      }

      if (link && linkLabel) {
        parts.push(
          `<a class="size-calculator__result-link" href="${encodeURI(link)}">${linkLabel}</a>`
        );
      }

      this.#result.innerHTML = parts.join('');
      this.#result.hidden = false;
    }

    #calculate() {
      const raw = this.#input?.value ?? '';

      if (raw.trim() === '') {
        this.#showError(this.dataset.errorEmpty || 'Enter a number.');
        return;
      }

      const value = Number(raw);
      const min = Number(this.dataset.inputMin);
      const max = Number(this.dataset.inputMax);

      if (Number.isNaN(value) || value < min || value > max) {
        this.#showError(this.dataset.errorRange || 'That number is out of range.');
        return;
      }

      this.#clearError();

      if (this.dataset.mode === 'ranges') {
        this.#calculateFromRanges(value);
        return;
      }

      this.#calculateFromFormula(value);
    }

    #calculateFromRanges(value) {
      const match = this.#ranges.find(
        (range) => value >= Number(range.min) && value <= Number(range.max)
      );

      if (!match) {
        this.#showError(this.dataset.errorRange || 'That number is out of range.');
        return;
      }

      this.#render(match.result, match.note, match.link, match.linkLabel);
    }

    #calculateFromFormula(value) {
      const multiplier = Number(this.dataset.multiplier) || 1;
      const offsetMin = Number(this.dataset.offsetMin) || 0;
      const offsetMax = Number(this.dataset.offsetMax) || 0;

      const low = this.#round(value * multiplier + offsetMin);
      const high = this.#round(value * multiplier + offsetMax);

      const output =
        low === high
          ? this.#format(low)
          : `${low} to ${this.#format(high)}`;

      this.#render(output, '', '', '');
    }
  }

  if (!customElements.get('size-calculator')) {
    customElements.define('size-calculator', SizeCalculator);
  }
{% endjavascript %}

{% schema %}
{
  "name": "Size calculator",
  "tag": "section",
  "class": "section-size-calculator",
  "max_blocks": 20,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Cabinet Hardware Size Calculator"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro text",
      "default": "<p>Enter your drawer width in inches to find the pull size that fits.</p>"
    },
    {
      "type": "text",
      "id": "input_label",
      "label": "Input label",
      "default": "Drawer width"
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input placeholder",
      "default": "Enter drawer width in inches"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Calculate"
    },
    {
      "type": "richtext",
      "id": "fallback_note",
      "label": "No JavaScript fallback",
      "info": "Shown only if scripts are blocked. Point people at the size chart.",
      "default": "<p>Use the size chart above to find your pull size.</p>"
    },
    {
      "type": "header",
      "content": "Calculation"
    },
    {
      "type": "select",
      "id": "calc_mode",
      "label": "How the result is worked out",
      "options": [
        {
          "value": "formula",
          "label": "Formula (multiply the input)"
        },
        {
          "value": "ranges",
          "label": "Ranges (look up a block)"
        }
      ],
      "default": "formula",
      "info": "Formula suits rules like one third of drawer width. Ranges suit custom charts."
    },
    {
      "type": "number",
      "id": "multiplier",
      "label": "Multiplier",
      "visible_if": "{{ section.settings.calc_mode == 'formula' }}",
      "info": "0.33 for the 1/3 pull rule. 1 for a same size result.",
      "default": 0.33
    },
    {
      "type": "number",
      "id": "offset_min",
      "label": "Low end offset",
      "visible_if": "{{ section.settings.calc_mode == 'formula' }}",
      "info": "Added to the low end of the answer. Use a negative number to subtract.",
      "default": 0
    },
    {
      "type": "number",
      "id": "offset_max",
      "label": "High end offset",
      "visible_if": "{{ section.settings.calc_mode == 'formula' }}",
      "info": "Added to the high end of the answer. Set both offsets the same for a single number.",
      "default": 1
    },
    {
      "type": "select",
      "id": "round_to",
      "label": "Round the answer to",
      "visible_if": "{{ section.settings.calc_mode == 'formula' }}",
      "options": [
        {
          "value": "0.25",
          "label": "Nearest quarter inch"
        },
        {
          "value": "0.5",
          "label": "Nearest half inch"
        },
        {
          "value": "1",
          "label": "Nearest inch"
        },
        {
          "value": "2",
          "label": "Nearest 2 inches"
        }
      ],
      "default": "1"
    },
    {
      "type": "text",
      "id": "result_prefix",
      "label": "Result prefix",
      "default": "Use a"
    },
    {
      "type": "text",
      "id": "result_suffix",
      "label": "Result suffix",
      "visible_if": "{{ section.settings.calc_mode == 'formula' }}",
      "default": "inch pull"
    },
    {
      "type": "text",
      "id": "unit_label",
      "label": "Unit label",
      "visible_if": "{{ section.settings.calc_mode == 'formula' }}",
      "default": ""
    },
    {
      "type": "header",
      "content": "Input limits and errors"
    },
    {
      "type": "number",
      "id": "input_min",
      "label": "Lowest number allowed",
      "default": 4
    },
    {
      "type": "number",
      "id": "input_max",
      "label": "Highest number allowed",
      "default": 96
    },
    {
      "type": "number",
      "id": "input_step",
      "label": "Input step",
      "default": 1
    },
    {
      "type": "text",
      "id": "error_empty",
      "label": "Empty input message",
      "default": "Enter a width in inches."
    },
    {
      "type": "text",
      "id": "error_range",
      "label": "Out of range message",
      "default": "Enter a width between 4 and 96 inches."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 320,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 720
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Button and link color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Box background",
      "default": "#f7f6f4"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e2e0dc"
    },
    {
      "type": "header",
      "content": "Heading type"
    },
    {
      "type": "text",
      "id": "heading_font_family",
      "label": "Font family",
      "info": "Leave blank to inherit the theme font. Or enter a stack such as Georgia, serif.",
      "default": ""
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Font size",
      "min": 14,
      "max": 56,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Font weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "heading_font_color",
      "label": "Font color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Body type"
    },
    {
      "type": "text",
      "id": "body_font_family",
      "label": "Font family",
      "default": ""
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "body_font_weight",
      "label": "Font weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "color",
      "id": "body_font_color",
      "label": "Font color",
      "default": "#3d3d3d"
    },
    {
      "type": "header",
      "content": "Result type"
    },
    {
      "type": "text",
      "id": "result_font_family",
      "label": "Font family",
      "default": ""
    },
    {
      "type": "range",
      "id": "result_font_size",
      "label": "Font size",
      "min": 16,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "select",
      "id": "result_font_weight",
