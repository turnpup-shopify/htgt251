<section
  class="product-highlight section-{{ section.id }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-bg: {{ section.settings.background_color }};
    --heading-color: {{ section.settings.heading_color }};
    --body-color: {{ section.settings.body_color }};
    --badge-bg: {{ section.settings.badge_background_color }};
    --badge-color: {{ section.settings.badge_text_color }};
    --card-bg: {{ section.settings.card_background_color }};
    --button-bg: {{ section.settings.button_background_color }};
    --button-color: {{ section.settings.button_text_color }};
    --price-color: {{ section.settings.price_text_color }};
    --heading-font: {% if section.settings.heading_font_family != blank %}{{ section.settings.heading_font_family }}{% else %}var(--font-heading-family){% endif %}, sans-serif;
    --body-font: {% if section.settings.body_font_family != blank %}{{ section.settings.body_font_family }}{% else %}var(--font-body-family){% endif %}, sans-serif;
  "
>
  <div class="product-highlight__container"> 
    {%- comment -%} Section Header {%- endcomment -%}
    <div class="product-highlight__header">
      <div class="product-highlight__header-text">
        {% if section.settings.heading != blank %}
          <h2 class="product-highlight__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <p class="product-highlight__description">{{ section.settings.description }}</p>
        {% endif %}
      </div>
      {% if section.settings.shop_all_label != blank %}
        <a href="{{ section.settings.shop_all_url }}" class="product-highlight__shop-all">
          {{ section.settings.shop_all_label }}
        </a>
      {% endif %}
    </div>

    {%- comment -%} Product Cards Grid {%- endcomment -%}
    {% if section.blocks.size > 0 %}
      <div class="product-highlight__grid">
        {% for block in section.blocks %}
          <a
            href="{{ block.settings.product_url }}"
            class="product-highlight__card"
            {{ block.shopify_attributes }}
          >
            <div class="product-highlight__card-image-wrapper">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 600
                  | image_tag:
                    class: 'product-highlight__card-image',
                    loading: 'lazy',
                    widths: '300, 400, 500, 600',
                    sizes: '(max-width: 767px) calc(100vw - 32px), (max-width: 991px) calc(50vw - 48px), (max-width: 1279px) calc(25vw - 48px), 280px'
                }}
              {% else %}
                <div class="product-highlight__card-placeholder">
                  {{ 'product-1' | placeholder_svg_tag: 'product-highlight__placeholder-svg' }}
                </div>
              {% endif %}

              {% if block.settings.badge_text != blank %}
                <span class="product-highlight__badge">{{ block.settings.badge_text }}</span>
              {% endif %}
            </div>

            <div class="product-highlight__card-content">
              {% if block.settings.product_code != blank %}
                <span class="product-highlight__product-code">{{ block.settings.product_code }}</span>
              {% endif %}

              {% if block.settings.product_name != blank %}
                <h3 class="product-highlight__product-name">{{ block.settings.product_name }}</h3>
              {% endif %}

              {% if block.settings.button_text != blank %}
                <span class="product-highlight__button">{{ block.settings.button_text }}</span>
              {% endif %}

              {% if block.settings.price_text != blank %}
                <span class="product-highlight__price">{{ block.settings.price_text }}</span>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% style %}
  /* ============================================
     Product Highlight Section
     ============================================ */

  .product-highlight {
    background-color: var(--section-bg, #fff);
  }

  /* Container */
  .product-highlight__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ---- Header ---- */
  .product-highlight__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 32px;
    gap: 24px;
  }

  .product-highlight__header-text {
    max-width: 640px;
  }

  .product-highlight__heading {
    font-family: var(--heading-font);
    font-size: 36px;
    font-weight: 700;
    line-height: 1.15;
    color: var(--heading-color, #2C3D50);
    margin: 0 0 12px;
  }

  .product-highlight__description {
    font-family: var(--body-font);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--body-color, #737373);
    margin: 0;
  }

  .product-highlight__shop-all {
    font-family: var(--body-font);
    font-size: 16px;
    font-weight: 600;
    color: var(--heading-color, #2C3D50);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }

  .product-highlight__shop-all:hover {
    opacity: 0.7;
  }

  /* ---- Product Cards Grid ---- */
  .product-highlight__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  /* ---- Card ---- */
  .product-highlight__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background-color: var(--card-bg, #F2FBFF);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .product-highlight__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  /* Card Image */
  .product-highlight__card-image-wrapper {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: var(--card-bg, #F2FBFF);
  }

  .product-highlight__card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-highlight__card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--card-bg, #F2FBFF);
  }

  .product-highlight__placeholder-svg {
    width: 60%;
    height: 60%;
    opacity: 0.4;
  }

  /* Badge */
  .product-highlight__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: var(--badge-bg, #486CED);
    color: var(--badge-color, #fff);
    font-family: var(--body-font);
    font-size: 12px;
    font-weight: 600;
    line-height: 1;
    padding: 6px 12px;
    border-radius: 50px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  /* Card Content */
  .product-highlight__card-content {
    display: flex;
    flex-direction: column;
    padding: 20px;
    gap: 4px;
    flex-grow: 1;
  }

  .product-highlight__product-code {
    font-family: var(--body-font);
    font-size: 14px;
    font-weight: 400;
    color: var(--body-color, #737373);
    letter-spacing: 0.02em;
  }

  .product-highlight__product-name {
    font-family: var(--heading-font);
    font-size: 18px;
    font-weight: 600;
    color: var(--heading-color, #2C3D50);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .product-highlight__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--button-bg, #2C3D50);
    color: var(--button-color, #fff);
    font-family: var(--body-font);
    font-size: 14px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.2s ease;
    margin-top: 8px;
    width: 100%;
    text-align: center;
  }

  .product-highlight__card:hover .product-highlight__button {
    opacity: 0.85;
  }

  .product-highlight__price {
    font-family: var(--body-font);
    font-size: 13px;
    font-weight: 400;
    color: var(--price-color, #737373);
    margin-top: 8px;
    text-align: center;
  }

  /* ============================================
     Responsive - Tablet (MD): 768 - 991px
     ============================================ */
  @media screen and (max-width: 991px) {
    .product-highlight__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .product-highlight__heading {
      font-size: 32px;
    }

    .product-highlight__description {
      font-size: 16px;
    }
  }

  /* ============================================
     Responsive - Mobile (SM): 0 - 767px
     ============================================ */
  @media screen and (max-width: 767px) {
    .product-highlight__container {
      padding: 0 16px;
    }

    .product-highlight__header {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: 24px;
      gap: 12px;
    }

    .product-highlight__heading {
      font-size: 26px;
    }

    .product-highlight__description {
      font-size: 14px;
    }

    .product-highlight__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .product-highlight__card-content {
      padding: 16px;
    }

    .product-highlight__product-name {
      font-size: 16px;
    }

    .product-highlight__button {
      font-size: 13px;
      padding: 8px 16px;
    }

    .product-highlight__badge {
      font-size: 11px;
      padding: 5px 10px;
      top: 8px;
      left: 8px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Product Highlight",
  "tag": "section",
  "class": "product-highlight-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Whole body health starts in the gut."
