      "label": "Section background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#2C3D50"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
