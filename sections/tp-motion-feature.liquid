{%- doc -%}
  Motion Feature — three static top panels + two auto-scrolling carousels.
  Middle carousel scrolls right→left. Bottom carousel scrolls left→right.
  On mobile, only the centre top panel is visible; carousels are hidden.
{%- enddoc -%}

{%- liquid
  assign top_blocks = section.blocks | where: 'type', 'top_item'
  assign mid_blocks = section.blocks | where: 'type', 'mid_item'
  assign bot_blocks = section.blocks | where: 'type', 'bot_item'
-%}

{% style %}
  #MotionFeature-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    gap: {{ section.settings.row_gap }}px;
  }

  @media screen and (min-width: 750px) {
    #MotionFeature-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  #MotionFeature-{{ section.id }} .mf-top {
    gap: {{ section.settings.top_gap }}px;
  }

  #MotionFeature-{{ section.id }} .mf-top__item {
    border-radius: {{ section.settings.item_radius }}px;
    aspect-ratio: {{ section.settings.top_aspect_ratio }};
  }

  #MotionFeature-{{ section.id }} .mf-track__inner {
    gap: {{ section.settings.carousel_gap }}px;
    animation-duration: {{ section.settings.carousel_speed }}s;
  }

  #MotionFeature-{{ section.id }} .mf-item {
    width: {{ section.settings.carousel_item_width_mobile }}px;
    aspect-ratio: {{ section.settings.carousel_aspect_ratio }};
    border-radius: {{ section.settings.item_radius }}px;
  }

  @media screen and (min-width: 750px) {
    #MotionFeature-{{ section.id }} .mf-item {
      width: {{ section.settings.carousel_item_width }}px;
    }
  }

{% endstyle %}

<section
  class="mf-section"
  id="MotionFeature-{{ section.id }}"
>

  {%- if section.settings.heading != blank -%}
    <h2 class="mf-heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  {%- if top_blocks.size > 0 -%}
    <div class="mf-top">
      {%- for block in top_blocks limit: 3 -%}
        <div
          class="mf-top__item{% if forloop.index == 2 %} mf-top__item--center{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 900
              | image_tag:
                class: 'mf-top__img',
                loading: 'lazy',
                alt: block.settings.image.alt | default: block.settings.title | escape
            }}
          {%- else -%}
            <div class="mf-placeholder">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}

          {%- if block.settings.overlay_opacity > 0 -%}
            <div
              class="mf-top__overlay"
              style="background:{{ block.settings.overlay_color }}; opacity:{{ block.settings.overlay_opacity | divided_by: 100.0 }};"
              aria-hidden="true"
            ></div>
          {%- endif -%}

          {%- if block.settings.title != blank or block.settings.subtext != blank -%}
            <div class="mf-top__text" style="color:{{ block.settings.text_color }};">
              {%- if block.settings.title != blank -%}
                <p class="mf-top__title">{{ block.settings.title | escape }}</p>
              {%- endif -%}
              {%- if block.settings.subtext != blank -%}
                <p class="mf-top__sub">{{ block.settings.subtext | escape }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if block.settings.link != blank -%}
            <a
              class="mf-top__cover-link"
              href="{{ block.settings.link }}"
              aria-label="{{ block.settings.title | default: 'View' | escape }}"
            ></a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if mid_blocks.size > 0 -%}
    <div class="mf-track mf-track--mid" aria-hidden="true">
      <div class="mf-track__inner mf-track__inner--forward">
        {%- for i in (1..2) -%}
          {%- for block in mid_blocks -%}
            <div class="mf-item"{% if i == 1 %} {{ block.shopify_attributes }}{% endif %}>
              {%- if block.settings.image != blank -%}
                {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" tabindex="-1" aria-hidden="true">{%- endif -%}
                {{ block.settings.image | image_url: width: 600
                  | image_tag:
                    class: 'mf-item__img',
                    loading: 'lazy',
                    alt: block.settings.image.alt | default: '' | escape
                }}
                {%- if block.settings.link != blank -%}</a>{%- endif -%}
              {%- else -%}
                <div class="mf-placeholder">{{ 'image' | placeholder_svg_tag }}</div>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <p class="mf-item__title">{{ block.settings.title | escape }}</p>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- if bot_blocks.size > 0 -%}
    <div class="mf-track mf-track--bot" aria-hidden="true">
      <div class="mf-track__inner mf-track__inner--reverse">
        {%- for i in (1..2) -%}
          {%- for block in bot_blocks -%}
            <div class="mf-item"{% if i == 1 %} {{ block.shopify_attributes }}{% endif %}>
              {%- if block.settings.image != blank -%}
                {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" tabindex="-1" aria-hidden="true">{%- endif -%}
                {{ block.settings.image | image_url: width: 600
                  | image_tag:
                    class: 'mf-item__img',
                    loading: 'lazy',
                    alt: block.settings.image.alt | default: '' | escape
                }}
                {%- if block.settings.link != blank -%}</a>{%- endif -%}
              {%- else -%}
                <div class="mf-placeholder">{{ 'image' | placeholder_svg_tag }}</div>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <p class="mf-item__title">{{ block.settings.title | escape }}</p>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</section>

{% stylesheet %}
  /* ── Motion Feature ──────────────────────────────────── */
  .mf-section {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .mf-heading {
    text-align: center;
    margin-block: 0 1.25rem;
  }

  /* ── Top 3 panels ──────────────────────────────────── */
  .mf-top {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .mf-top__item {
    position: relative;
    overflow: hidden;
  }

  .mf-top__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mf-top__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .mf-top__text {
    position: absolute;
    inset-inline: 1rem;
    bottom: 1.25rem;
    z-index: 1;
    pointer-events: none;
  }

  .mf-top__title {
    margin-block: 0 0.25rem;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .mf-top__sub {
    margin-block: 0;
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .mf-top__cover-link {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  /* ── Carousel tracks ───────────────────────────────── */
  .mf-track {
    overflow: hidden;
    width: 100%;
  }

  .mf-track__inner {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .mf-track__inner--forward {
    animation: mf-scroll-forward linear infinite;
  }

  .mf-track__inner--reverse {
    animation: mf-scroll-reverse linear infinite;
    transform: translateX(-50%); /* match animation 'from' to prevent flash */
  }

  /* ── Carousel items ────────────────────────────────── */
  .mf-item {
    flex: 0 0 auto;
    overflow: hidden;
    position: relative;
  }

  .mf-item a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .mf-item__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mf-item__title {
    margin-block: 0.5rem 0;
    font-size: 0.875rem;
    line-height: 1.3;
    padding-inline: 0.25rem;
  }

  /* ── Placeholder ───────────────────────────────────── */
  .mf-placeholder {
    width: 100%;
    height: 100%;
    min-height: 160px;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mf-placeholder svg {
    width: 48px;
    height: 48px;
    opacity: 0.3;
  }

  /* ── Keyframes ─────────────────────────────────────── */
  @keyframes mf-scroll-forward {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes mf-scroll-reverse {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mf-track__inner--forward,
    .mf-track__inner--reverse {
      animation: none;
      transform: none;
    }
  }

  /* ── Mobile ────────────────────────────────────────── */
  @media screen and (max-width: 749px) {
    .mf-top {
      grid-template-columns: 1fr;
    }

    .mf-top__item:not(.mf-top__item--center) {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Motion Feature",
  "tag": "section",
  "class": "motion-feature-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "row_gap",
      "label": "Gap between rows",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "top_gap",
      "label": "Gap between top panels",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "item_radius",
      "label": "Corner radius (all items)",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "select",
      "id": "top_aspect_ratio",
      "label": "Top panel proportions",
      "options": [
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "2 / 3", "label": "Tall portrait (2:3)" },
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" },
        { "value": "16 / 9", "label": "Widescreen (16:9)" }
      ],
      "default": "3 / 4"
    },
    {
      "type": "header",
      "content": "Carousels"
    },
    {
      "type": "range",
      "id": "carousel_speed",
      "label": "Scroll speed (seconds per loop)",
      "min": 5,
      "max": 120,
      "step": 5,
      "unit": "s",
      "default": 30
    },
    {
      "type": "range",
      "id": "carousel_item_width",
      "label": "Item width (desktop)",
      "min": 100,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "carousel_item_width_mobile",
      "label": "Item width (mobile)",
      "min": 60,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 160
    },
    {
      "type": "select",
      "id": "carousel_aspect_ratio",
      "label": "Item proportions",
      "options": [
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" },
        { "value": "16 / 9", "label": "Widescreen (16:9)" }
      ],
      "default": "4 / 3"
    },
    {
      "type": "range",
      "id": "carousel_gap",
      "label": "Gap between items",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "name": "Top Panel",
      "type": "top_item",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay opacity",
          "min": 0,
          "max": 80,
          "step": 5,
          "default": 0
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#ffffff"
        }
      ]
    },
    {
      "name": "Middle Carousel Item",
      "type": "mid_item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Caption"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "name": "Bottom Carousel Item",
      "type": "bot_item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Caption"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Motion Feature",
      "blocks": [
        { "type": "top_item" },
        { "type": "top_item" },
        { "type": "top_item" },
        { "type": "mid_item" },
        { "type": "mid_item" },
        { "type": "mid_item" },
        { "type": "mid_item" },
        { "type": "bot_item" },
        { "type": "bot_item" },
        { "type": "bot_item" },
        { "type": "bot_item" }
      ]
    }
  ]
}
{% endschema %}
