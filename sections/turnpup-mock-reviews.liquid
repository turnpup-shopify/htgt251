<!-- CUSTOM SECTION PADDING - START -->
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-right: {{ section.settings.mobile_padding_right }}px;
    padding-left: {{ section.settings.mobile_padding_left }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-right: {{ section.settings.padding_right }}px;
      padding-left: {{ section.settings.padding_left }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .turnpup-mock-reviews .jdgm-rev-widg {
    max-width: 920px;
    margin: 0 auto;
    color: #111;
    font-family: inherit;
  }

  .turnpup-mock-reviews .jdgm-rev-widg__header {
    text-align: center;
  }

  .turnpup-mock-reviews .jdgm-rev-widg__title {
    display: block !important;
    visibility: visible !important;
    margin: 0 0 12px;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 0.2px;
    color: #111;
  }

  .turnpup-mock-reviews .jdgm-row-stars {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .turnpup-mock-reviews .jdgm-rev-widg__summary-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .turnpup-mock-reviews .jdgm-rev-widg__summary-stars {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    color: #555;
  }

  .turnpup-mock-reviews .jdgm-rev-widg__summary-text {
    font-size: 16px;
    color: #555;
  }

  .turnpup-mock-reviews .jdgm-star {
    display: inline-block;
    width: 18px;
    height: 18px;
    background-repeat: no-repeat;
    background-size: contain;
    background-position: center;
  }

  .turnpup-mock-reviews .jdgm-star.jdgm--on {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='black'><path d='M12 2.5l2.9 5.9 6.5.9-4.7 4.6 1.1 6.5L12 17.7 6.2 20.4l1.1-6.5L2.6 9.3l6.5-.9L12 2.5z'/></svg>");
  }

  .turnpup-mock-reviews .jdgm-star.jdgm--off {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23bbb' stroke-width='1.6'><path d='M12 2.5l2.9 5.9 6.5.9-4.7 4.6 1.1 6.5L12 17.7 6.2 20.4l1.1-6.5L2.6 9.3l6.5-.9L12 2.5z'/></svg>");
  }

  .turnpup-mock-reviews .jdgm-star::before {
    content: none !important;
    display: none !important;
  }

  .turnpup-mock-reviews .jdgm-histogram,
  .turnpup-mock-reviews .jdgm-form-wrapper,
  .turnpup-mock-reviews .jdgm-form-dynamic-wrapper,
  .turnpup-mock-reviews .jdgm-rev__custom-form,
  .turnpup-mock-reviews .jdgm-rev__actions,
  .turnpup-mock-reviews .jdgm-rev__transparency-badge-wrapper,
  .turnpup-mock-reviews .jdgm-paginate,
  .turnpup-mock-reviews .jdgm-rev-widg__paginate-spinner-wrapper {
    display: none !important;
  }

  .turnpup-mock-reviews .jdgm-rev {
    border-top: 1px solid #e5e5e5;
    padding: 20px 0;
  }

  .turnpup-mock-reviews .jdgm-rev__header {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "rating date"
      "profile profile";
    row-gap: 10px;
    align-items: center;
  }

  .turnpup-mock-reviews .jdgm-row-rating {
    grid-area: rating;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .turnpup-mock-reviews .jdgm-rev__rating {
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }

  .turnpup-mock-reviews .jdgm-rev__timestamp {
    grid-area: date;
    font-size: 14px;
    color: #777;
  }

  .turnpup-mock-reviews .jdgm-row-profile {
    grid-area: profile;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .turnpup-mock-reviews .jdgm-rev__author {
    font-size: 18px;
    font-weight: 500;
  }

  .turnpup-mock-reviews .jdgm-rev__content {
    margin-top: 10px;
  }

  .turnpup-mock-reviews .jdgm-rev__title {
    display: block;
    font-size: 18px;
    font-weight: 700;
    margin: 8px 0 6px;
  }

  .turnpup-mock-reviews .jdgm-rev__body {
    font-size: 16px;
    color: #444;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .turnpup-mock-reviews .jdgm-rev-widg__title {
      font-size: 24px;
    }

    .turnpup-mock-reviews .jdgm-rev__header {
      grid-template-columns: 1fr auto;
    }

    .turnpup-mock-reviews .jdgm-rev__author {
      font-size: 16px;
    }
  }

  /* Carousel dots — hidden on desktop */
  .turnpup-mock-reviews .jdgm-rev-carousel-dots {
    display: none;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }

  .turnpup-mock-reviews .jdgm-rev-carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ccc;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .turnpup-mock-reviews .jdgm-rev-carousel-dot.is-active {
    background: #111;
  }

  @media screen and (max-width: 749px) {
    .turnpup-mock-reviews .jdgm-rev-widg__reviews {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .turnpup-mock-reviews .jdgm-rev-widg__reviews::-webkit-scrollbar {
      display: none;
    }

    .turnpup-mock-reviews .jdgm-rev {
      scroll-snap-align: start;
      flex: 0 0 100%;
      min-width: 100%;
    }

    .turnpup-mock-reviews .jdgm-rev-carousel-dots {
      display: flex;
    }
  }
{%- endstyle -%}
<!-- CUSTOM SECTION PADDING - END -->

<section id="mock-reviews" class="section-{{ section.id }}-padding">
  {%- liquid
    assign review_count = section.blocks.size
    assign total_score = 0
    for block in section.blocks
      assign total_score = total_score | plus: block.settings.rating
    endfor
 
    assign average_rating = 0
    if review_count > 0
      assign average_rating = total_score | times: 1.0 | divided_by: review_count | round: 2
    else
      assign review_count = 4
      assign average_rating = 4.75
    endif
    assign rounded_average = average_rating | round
  -%}

  <div class="jdgm-rev-widg" data-average-rating="{{ average_rating }}" data-number-of-reviews="{{ review_count }}">
    <div class="jdgm-rev-widg__header">
      <h2 class="jdgm-rev-widg__title">{{ section.settings.heading | default: 'Customer Reviews' }}</h2>
      <div class="jdgm-row-stars">
        <div class="jdgm-rev-widg__summary">
          <div class="jdgm-rev-widg__summary-inner">
            <div class="jdgm-rev-widg__summary-stars" aria-label="Average rating is {{ average_rating }} stars" role="img">
              {%- for star_index in (1..5) -%}
                <span class="jdgm-star {% if star_index <= rounded_average %}jdgm--on{% else %}jdgm--off{% endif %}"></span>
              {%- endfor -%}
              <span class="jdgm-rev-widg__summary-average">{{ average_rating }} out of 5</span>
            </div>
            <div class="jdgm-rev-widg__summary-text">
              Based on {{ review_count }} {% if review_count == 1 %}review{% else %}reviews{% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="jdgm-rev-widg__body">
      <div class="jdgm-rev-widg__reviews">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- assign block_rating = block.settings.rating | default: 5 | plus: 0 -%}
            <div class="jdgm-rev jdgm-divider-top jdgm--done-setup" {{ block.shopify_attributes }}>
              <div class="jdgm-rev__header">
                <div class="jdgm-row-product"></div>
                <div class="jdgm-row-rating">
                  <span class="jdgm-rev__rating" data-score="{{ block_rating }}" tabindex="0" aria-label="{{ block_rating }} star review" role="img">
                    {%- for star_index in (1..5) -%}
                      <span class="jdgm-star {% if star_index <= block_rating %}jdgm--on{% else %}jdgm--off{% endif %}"></span>
                    {%- endfor -%}
                  </span>
                  <span class="jdgm-rev__timestamp">{{ block.settings.date }}</span>
                </div>
                <div class="jdgm-row-profile">
<span class="jdgm-rev__author-wrapper">
                    <span class="jdgm-rev__author">{{ block.settings.author | escape }}</span>
                  </span>
                </div>
                <div class="jdgm-row-extra"><span class="jdgm-rev__location"></span></div>
                <div class="jdgm-rev__br"></div>
              </div>
              <div class="jdgm-rev__content">
                {%- if block.settings.title != blank -%}
                  <b class="jdgm-rev__title">{{ block.settings.title | escape }}</b>
                {%- endif -%}
                <div class="jdgm-rev__body">
                  <p>{{ block.settings.body | escape | newline_to_br }}</p>
                </div>
                <div class="jdgm-rev__custom-form"></div>
              </div>
              <div class="jdgm-rev__actions">
                <div class="jdgm-rev__social"></div>
                <div class="jdgm-rev__votes"></div>
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="jdgm-rev jdgm-divider-top jdgm--done-setup">
            <div class="jdgm-rev__header">
              <div class="jdgm-row-product"></div>
              <div class="jdgm-row-rating">
                <span class="jdgm-rev__rating" data-score="5" tabindex="0" aria-label="5 star review" role="img">
                  <span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span>
                </span>
                <span class="jdgm-rev__timestamp">12/14/2025</span>
              </div>
              <div class="jdgm-row-profile">
<span class="jdgm-rev__author-wrapper">
                  <span class="jdgm-rev__author">Blake</span>
                </span>
              </div>
              <div class="jdgm-row-extra"><span class="jdgm-rev__location"></span></div>
              <div class="jdgm-rev__br"></div>
            </div>
            <div class="jdgm-rev__content">
              <b class="jdgm-rev__title">Perfect for my apartment hallway</b>
              <div class="jdgm-rev__body">
                <p>Love this bench for my apartment entryway. Love that it has a small shelf under the bench seat.</p>
              </div>
            </div>
          </div>
          <div class="jdgm-rev jdgm-divider-top jdgm--done-setup">
            <div class="jdgm-rev__header">
              <div class="jdgm-row-product"></div>
              <div class="jdgm-row-rating">
                <span class="jdgm-rev__rating" data-score="5" tabindex="0" aria-label="5 star review" role="img">
                  <span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span>
                </span>
                <span class="jdgm-rev__timestamp">03/25/2025</span>
              </div>
              <div class="jdgm-row-profile">
<span class="jdgm-rev__author-wrapper">
                  <span class="jdgm-rev__author">Paul T</span>
                </span>
              </div>
              <div class="jdgm-row-extra"><span class="jdgm-rev__location"></span></div>
              <div class="jdgm-rev__br"></div>
            </div>
            <div class="jdgm-rev__content">
              <div class="jdgm-rev__body">
                <p>I love the unique design. Definitely a statement piece!</p>
              </div>
            </div>
          </div>
          <div class="jdgm-rev jdgm-divider-top jdgm--done-setup">
            <div class="jdgm-rev__header">
              <div class="jdgm-row-product"></div>
              <div class="jdgm-row-rating">
                <span class="jdgm-rev__rating" data-score="5" tabindex="0" aria-label="5 star review" role="img">
                  <span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span>
                </span>
                <span class="jdgm-rev__timestamp">08/29/2022</span>
              </div>
              <div class="jdgm-row-profile">
<span class="jdgm-rev__author-wrapper">
                  <span class="jdgm-rev__author">Elliot O</span>
                </span>
              </div>
              <div class="jdgm-row-extra"><span class="jdgm-rev__location"></span></div>
              <div class="jdgm-rev__br"></div>
            </div>
            <div class="jdgm-rev__content">
              <div class="jdgm-rev__body">
                <p>This is exactly what I needed for my space. The perfect size and style.</p>
              </div>
            </div>
          </div>
          <div class="jdgm-rev jdgm-divider-top jdgm--done-setup">
            <div class="jdgm-rev__header">
              <div class="jdgm-row-product"></div>
              <div class="jdgm-row-rating">
                <span class="jdgm-rev__rating" data-score="4" tabindex="0" aria-label="4 star review" role="img">
                  <span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--off"></span>
                </span>
                <span class="jdgm-rev__timestamp">04/26/2022</span>
              </div>
              <div class="jdgm-row-profile">
<span class="jdgm-rev__author-wrapper">
                  <span class="jdgm-rev__author">Ryan Y</span>
                </span>
              </div>
              <div class="jdgm-row-extra"><span class="jdgm-rev__location"></span></div>
              <div class="jdgm-rev__br"></div>
            </div>
            <div class="jdgm-rev__content">
              <div class="jdgm-rev__body">
                <p>The finish is flawless. Looks so polished!</p>
              </div>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
    <div class="jdgm-rev-carousel-dots" aria-hidden="true"></div>
  </div>
</section>

<script>
(function () {
  var mockSection = document.getElementById('mock-reviews');
  if (!mockSection) return;

  function hideJudgeMeEmptyWidgets() {
    var widgets = document.querySelectorAll('.jdgm-rev-widg[data-number-of-reviews="0"]');
    for (var i = 0; i < widgets.length; i++) {
      var el = widgets[i];
      while (el && !el.classList.contains('shopify-app-block')) {
        el = el.parentElement;
      }
      if (el) el.style.display = 'none';
    }
  }

  function checkForRealReviews() {
    var appBlocks = document.querySelectorAll('.shopify-app-block');
    for (var i = 0; i < appBlocks.length; i++) {
      if (appBlocks[i].querySelectorAll('.jdgm-rev').length > 0) {
        mockSection.style.display = 'none';
        return true;
      }
    }
    return false;
  }

  if (!checkForRealReviews()) {
    hideJudgeMeEmptyWidgets();
    var observer = new MutationObserver(function () {
      if (checkForRealReviews()) {
        observer.disconnect();
      } else {
        hideJudgeMeEmptyWidgets();
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });
  }

  // Swipe carousel dots (mobile only)
  var reviewsEl = mockSection.querySelector('.jdgm-rev-widg__reviews');
  var dotsEl = mockSection.querySelector('.jdgm-rev-carousel-dots');
  if (reviewsEl && dotsEl) {
    var reviews = Array.prototype.slice.call(reviewsEl.querySelectorAll('.jdgm-rev'));
    reviews.forEach(function(_, i) {
      var dot = document.createElement('button');
      dot.className = 'jdgm-rev-carousel-dot' + (i === 0 ? ' is-active' : '');
      dot.setAttribute('type', 'button');
      dot.setAttribute('aria-label', 'Go to review ' + (i + 1));
      dot.addEventListener('click', function() {
        reviewsEl.scrollTo({ left: i * reviewsEl.offsetWidth, behavior: 'smooth' });
      });
      dotsEl.appendChild(dot);
    });

    reviewsEl.addEventListener('scroll', function() {
      var active = Math.round(reviewsEl.scrollLeft / (reviewsEl.offsetWidth || 1));
      var dots = dotsEl.querySelectorAll('.jdgm-rev-carousel-dot');
      for (var j = 0; j < dots.length; j++) {
        dots[j].classList.toggle('is-active', j === active);
      }
    }, { passive: true });
  }
})();
</script>

