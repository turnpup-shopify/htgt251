<!-- CUSTOM SECTION PADDING - START -->
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-right: {{ section.settings.mobile_padding_right }}px;
    padding-left: {{ section.settings.mobile_padding_left }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-right: {{ section.settings.padding_right }}px;
      padding-left: {{ section.settings.padding_left }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .turnpup-mock-reviews .jdgm-rev-widg {
    max-width: 920px;
    margin: 0 auto;
    color: #111;
    font-family: inherit;
  }

  .turnpup-mock-reviews .jdgm-rev-widg__header {
    text-align: center;
  }

  .turnpup-mock-reviews .jdgm-rev-widg__title {
    margin: 0 0 12px;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 0.2px;
  }

  .turnpup-mock-reviews .jdgm-row-stars {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .turnpup-mock-reviews .jdgm-rev-widg__summary-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .turnpup-mock-reviews .jdgm-rev-widg__summary-stars {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    color: #555;
  }

  .turnpup-mock-reviews .jdgm-rev-widg__summary-text {
    font-size: 16px;
    color: #555;
  }

  .turnpup-mock-reviews .jdgm-star {
    display: inline-block;
    width: 18px;
    height: 18px;
    background-repeat: no-repeat;
    background-size: contain;
    background-position: center;
  }

  .turnpup-mock-reviews .jdgm-star.jdgm--on {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='black'><path d='M12 2.5l2.9 5.9 6.5.9-4.7 4.6 1.1 6.5L12 17.7 6.2 20.4l1.1-6.5L2.6 9.3l6.5-.9L12 2.5z'/></svg>");
  }

  .turnpup-mock-reviews .jdgm-star.jdgm--off {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23bbb' stroke-width='1.6'><path d='M12 2.5l2.9 5.9 6.5.9-4.7 4.6 1.1 6.5L12 17.7 6.2 20.4l1.1-6.5L2.6 9.3l6.5-.9L12 2.5z'/></svg>");
  }

  .turnpup-mock-reviews .jdgm-widget-actions-wrapper {
    width: 100%;
    margin: 18px 0 4px;
  }

  .turnpup-mock-reviews .jdgm-write-rev-link {
    display: block;
    width: 100%;
    padding: 14px 16px;
    background: #000;
    color: #fff;
    font-weight: 700;
    text-align: center;
    text-transform: none;
    letter-spacing: 0.2px;
    text-decoration: none;
  }

  .turnpup-mock-reviews .jdgm-histogram,
  .turnpup-mock-reviews .jdgm-form-wrapper,
  .turnpup-mock-reviews .jdgm-form-dynamic-wrapper,
  .turnpup-mock-reviews .jdgm-rev__custom-form,
  .turnpup-mock-reviews .jdgm-rev__actions,
  .turnpup-mock-reviews .jdgm-rev__transparency-badge-wrapper,
  .turnpup-mock-reviews .jdgm-paginate,
  .turnpup-mock-reviews .jdgm-rev-widg__paginate-spinner-wrapper {
    display: none !important;
  }

  .turnpup-mock-reviews .jdgm-row-actions {
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    margin: 18px 0 8px;
    padding: 16px 0;
  }

  .turnpup-mock-reviews .jdgm-rev-widg__sort-wrapper {
    text-align: left;
  }

  .turnpup-mock-reviews .jdgm-sort-dropdown-wrapper {
    position: relative;
    display: inline-block;
  }

  .turnpup-mock-reviews .jdgm-sort-dropdown {
    border: none;
    background: transparent;
    font-size: 16px;
    font-weight: 500;
    color: #111;
    padding: 4px 28px 4px 0;
    appearance: none;
  }

  .turnpup-mock-reviews .jdgm-sort-dropdown-arrow {
    position: absolute;
    right: 4px;
    top: 50%;
    width: 10px;
    height: 6px;
    transform: translateY(-50%);
    pointer-events: none;
    background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 10 6' fill='none' stroke='black' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><path d='M1 1l4 4 4-4'/></svg>") no-repeat center/contain;
  }

  .turnpup-mock-reviews .jdgm-rev {
    border-top: 1px solid #e5e5e5;
    padding: 20px 0;
  }

  .turnpup-mock-reviews .jdgm-rev__header {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "rating date"
      "profile profile";
    row-gap: 10px;
    align-items: center;
  }

  .turnpup-mock-reviews .jdgm-row-rating {
    grid-area: rating;
  }

  .turnpup-mock-reviews .jdgm-rev__timestamp {
    grid-area: date;
    font-size: 14px;
    color: #777;
  }

  .turnpup-mock-reviews .jdgm-row-profile {
    grid-area: profile;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .turnpup-mock-reviews .jdgm-rev__icon {
    width: 44px;
    height: 44px;
    border-radius: 6px;
    background: #f0f0f0;
    position: relative;
  }

  .turnpup-mock-reviews .jdgm-rev__icon::before {
    content: "";
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='8' r='3.2'/><path d='M5 20c0-3.2 3.1-5.4 7-5.4s7 2.2 7 5.4'/></svg>") no-repeat center/22px 22px;
  }

  .turnpup-mock-reviews .jdgm-rev__author {
    font-size: 18px;
    font-weight: 500;
  }

  .turnpup-mock-reviews .jdgm-rev__content {
    margin-top: 10px;
  }

  .turnpup-mock-reviews .jdgm-rev__title {
    display: block;
    font-size: 18px;
    font-weight: 700;
    margin: 8px 0 6px;
  }

  .turnpup-mock-reviews .jdgm-rev__body {
    font-size: 16px;
    color: #444;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .turnpup-mock-reviews .jdgm-rev-widg__title {
      font-size: 24px;
    }

    .turnpup-mock-reviews .jdgm-rev__header {
      grid-template-columns: 1fr auto;
    }

    .turnpup-mock-reviews .jdgm-rev__author {
      font-size: 16px;
    }
  }
{%- endstyle -%}
<!-- CUSTOM SECTION PADDING - END -->

<section id="mock-reviews" class="section-{{ section.id }}-padding">
  {%- liquid
    assign review_count = section.blocks.size
    assign total_score = 0
    for block in section.blocks
      assign total_score = total_score | plus: block.settings.rating
    endfor
 
    assign average_rating = 0
    if review_count > 0
      assign average_rating = total_score | times: 1.0 | divided_by: review_count | round: 2
    else
      assign review_count = 4
      assign average_rating = 4.75
    endif
    assign rounded_average = average_rating | round
  -%}

  <div class="jdgm-rev-widg" data-average-rating="{{ average_rating }}" data-number-of-reviews="{{ review_count }}">
    <div class="jdgm-rev-widg__header">
      <h2 class="jdgm-rev-widg__title">{{ section.settings.heading }}</h2>
      <div class="jdgm-row-stars">
        <div class="jdgm-rev-widg__summary">
          <div class="jdgm-rev-widg__summary-inner">
            <div class="jdgm-rev-widg__summary-stars" aria-label="Average rating is {{ average_rating }} stars" role="img">
              {%- for star_index in (1..5) -%}
                <span class="jdgm-star {% if star_index <= rounded_average %}jdgm--on{% else %}jdgm--off{% endif %}"></span>
              {%- endfor -%}
              <span class="jdgm-rev-widg__summary-average">{{ average_rating }} out of 5</span>
            </div>
            <div class="jdgm-rev-widg__summary-text">
              Based on {{ review_count }} {% if review_count == 1 %}review{% else %}reviews{% endif %}
            </div>
          </div>
        </div>
        {%- if section.settings.write_review_text != blank -%}
          <div class="jdgm-widget-actions-wrapper">
            <a href="{{ section.settings.write_review_link | default: '#' }}" class="jdgm-write-rev-link" role="button" aria-expanded="false">
              {{ section.settings.write_review_text }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="jdgm-row-actions">
      <div class="jdgm-rev-widg__sort-wrapper">
        <div class="jdgm-sort-dropdown-wrapper">
          <select class="jdgm-sort-dropdown" aria-label="Sort dropdown">
            <option value="most-recent">Most Recent</option>
            <option value="highest-rating">Highest Rating</option>
            <option value="lowest-rating">Lowest Rating</option>
            <option value="with-pictures">Only Pictures</option>
            <option value="pictures-first">Pictures First</option>
            <option value="videos-first">Videos First</option>
            <option value="most-helpful">Most Helpful</option>
          </select>
          <span class="jdgm-sort-dropdown-arrow"></span>
        </div>
      </div>
    </div>

    <div class="jdgm-rev-widg__body">
      <div class="jdgm-rev-widg__reviews">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <div class="jdgm-rev jdgm-divider-top jdgm--done-setup" {{ block.shopify_attributes }}>
              <div class="jdgm-rev__header">
                <div class="jdgm-row-product"></div>
                <div class="jdgm-row-rating">
                  <span class="jdgm-rev__rating" data-score="{{ block.settings.rating }}" tabindex="0" aria-label="{{ block.settings.rating }} star review" role="img">
                    {%- for star_index in (1..5) -%}
                      <span class="jdgm-star {% if star_index <= block.settings.rating %}jdgm--on{% else %}jdgm--off{% endif %}"></span>
                    {%- endfor -%}
                  </span>
                  <span class="jdgm-rev__timestamp">{{ block.settings.date }}</span>
                </div>
                <div class="jdgm-row-profile">
                  <div class="jdgm-rev__icon"></div>
                  <span class="jdgm-rev__author-wrapper">
                    <span class="jdgm-rev__author">{{ block.settings.author | escape }}</span>
                  </span>
                </div>
                <div class="jdgm-row-extra"><span class="jdgm-rev__location"></span></div>
                <div class="jdgm-rev__br"></div>
              </div>
              <div class="jdgm-rev__content">
                {%- if block.settings.title != blank -%}
                  <b class="jdgm-rev__title">{{ block.settings.title | escape }}</b>
                {%- endif -%}
                <div class="jdgm-rev__body">
                  <p>{{ block.settings.body | escape | newline_to_br }}</p>
                </div>
                <div class="jdgm-rev__custom-form"></div>
              </div>
              <div class="jdgm-rev__actions">
                <div class="jdgm-rev__social"></div>
                <div class="jdgm-rev__votes"></div>
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="jdgm-rev jdgm-divider-top jdgm--done-setup">
            <div class="jdgm-rev__header">
              <div class="jdgm-row-product"></div>
              <div class="jdgm-row-rating">
                <span class="jdgm-rev__rating" data-score="5" tabindex="0" aria-label="5 star review" role="img">
                  <span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span>
                </span>
                <span class="jdgm-rev__timestamp">12/14/2025</span>
              </div>
              <div class="jdgm-row-profile">
                <div class="jdgm-rev__icon"></div>
                <span class="jdgm-rev__author-wrapper">
                  <span class="jdgm-rev__author">Blake</span>
                </span>
              </div>
              <div class="jdgm-row-extra"><span class="jdgm-rev__location"></span></div>
              <div class="jdgm-rev__br"></div>
            </div>
            <div class="jdgm-rev__content">
              <b class="jdgm-rev__title">Perfect for my apartment hallway</b>
              <div class="jdgm-rev__body">
                <p>Love this bench for my apartment entryway. Love that it has a small shelf under the bench seat.</p>
              </div>
            </div>
          </div>
          <div class="jdgm-rev jdgm-divider-top jdgm--done-setup">
            <div class="jdgm-rev__header">
              <div class="jdgm-row-product"></div>
              <div class="jdgm-row-rating">
                <span class="jdgm-rev__rating" data-score="5" tabindex="0" aria-label="5 star review" role="img">
                  <span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span>
                </span>
                <span class="jdgm-rev__timestamp">03/25/2025</span>
              </div>
              <div class="jdgm-row-profile">
                <div class="jdgm-rev__icon"></div>
                <span class="jdgm-rev__author-wrapper">
                  <span class="jdgm-rev__author">Paul T</span>
                </span>
              </div>
              <div class="jdgm-row-extra"><span class="jdgm-rev__location"></span></div>
              <div class="jdgm-rev__br"></div>
            </div>
            <div class="jdgm-rev__content">
              <div class="jdgm-rev__body">
                <p>I love the unique design. Definitely a statement piece!</p>
              </div>
            </div>
          </div>
          <div class="jdgm-rev jdgm-divider-top jdgm--done-setup">
            <div class="jdgm-rev__header">
              <div class="jdgm-row-product"></div>
              <div class="jdgm-row-rating">
                <span class="jdgm-rev__rating" data-score="5" tabindex="0" aria-label="5 star review" role="img">
                  <span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span>
                </span>
                <span class="jdgm-rev__timestamp">08/29/2022</span>
              </div>
              <div class="jdgm-row-profile">
                <div class="jdgm-rev__icon"></div>
                <span class="jdgm-rev__author-wrapper">
                  <span class="jdgm-rev__author">Elliot O</span>
                </span>
              </div>
              <div class="jdgm-row-extra"><span class="jdgm-rev__location"></span></div>
              <div class="jdgm-rev__br"></div>
            </div>
            <div class="jdgm-rev__content">
              <div class="jdgm-rev__body">
                <p>This is exactly what I needed for my space. The perfect size and style.</p>
              </div>
            </div>
          </div>
          <div class="jdgm-rev jdgm-divider-top jdgm--done-setup">
            <div class="jdgm-rev__header">
              <div class="jdgm-row-product"></div>
              <div class="jdgm-row-rating">
                <span class="jdgm-rev__rating" data-score="4" tabindex="0" aria-label="4 star review" role="img">
                  <span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--on"></span><span class="jdgm-star jdgm--off"></span>
                </span>
                <span class="jdgm-rev__timestamp">04/26/2022</span>
              </div>
              <div class="jdgm-row-profile">
                <div class="jdgm-rev__icon"></div>
                <span class="jdgm-rev__author-wrapper">
                  <span class="jdgm-rev__author">Ryan Y</span>
                </span>
              </div>
              <div class="jdgm-row-extra"><span class="jdgm-rev__location"></span></div>
              <div class="jdgm-rev__br"></div>
            </div>
            <div class="jdgm-rev__content">
              <div class="jdgm-rev__body">
                <p>The finish is flawless. Looks so polished!</p>
              </div>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Turnpup Mock Reviews",
  "tag": "section",
  "class": "section turnpup-mock-reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "write_review_text",
      "label": "Write review button text",
      "default": "Write a review"
    },
    {
      "type": "url",
      "id": "write_review_link",
      "label": "Write review button link"
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Right",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Left",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Bottom",
      "default": 40
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Top",
      "default": 32
    },
    {
      "type": "range",
      "id": "mobile_padding_right",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Right",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_left",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Left",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Bottom",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Blake"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "12/14/2025"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review title",
          "default": "Perfect for my apartment hallway"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Review body",
          "default": "Love this bench for my apartment entryway. Love that it has a small shelf under the bench seat."
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Turnpup Mock Reviews",
      "category": "Custom PDP",
      "blocks": [
        {
          "type": "review"
        },
        {
          "type": "review"
        },
        {
          "type": "review"
        }
      ]
    }
  ]
}
{% endschema %}
